# Copy this file to .env and fill in real credentials.
# Never commit .env.

# Single Google API key for text / image / video generation.
GEMINI_API_KEY=
GOOGLE_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Core model selection.
SCRIPT_MODEL=gemini-2.5-flash
OPENROUTER_API_KEY=
IMAGE_MODEL=openai/gpt-5.4-image-2
META_MODEL=gemini-2.5-flash
VISION_MODEL=gemini-2.5-flash
VIDEO_MODEL=veo-3.1-generate-preview
VIDEO_PROVIDER=google
VIDEO_RESOLUTION=1080p
VIDEO_REFERENCE_MODE=image
VIDEO_HTTP_TIMEOUT_SECONDS=180
USE_GENERATED_VIDEO_AUDIO=true

# Optional local subtitle styling.
SUBTITLE_FONT_NAME=Cambria
SUBTITLE_FONT_SIZE=13
SUBTITLE_MARGIN_V=52

# Optional S3/RustFS-compatible storage.
RUSTFS_ENDPOINT=
RUSTFS_ACCESS_KEY=
RUSTFS_ACCESS_SECRET=
RUSTFS_BUCKET_NAME_VIDEO=video-clips
RUSTFS_BUCKET_NAME_AUDIO=audio-clips

# Optional integrations.
YOUTUBE_API_KEY=
GOOGLE_API_KEY=
DASHSCOPE_API_KEY=
CAPCUT_API_URL=http://localhost:9000

# Optional Meta ad operations.
# Never hardcode these into source files.
META_ACCESS_TOKEN=
FACEBOOK_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_PAGE_ID=
META_DEFAULT_ADSET_ID=
META_DEFAULT_LANDING_PAGE_URL=
META_ADS_READ_ONLY=true
