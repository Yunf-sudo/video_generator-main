# Copy this file to .env and fill in real credentials.
# Never commit .env.

# Text/image/TTS provider used by the current pipeline.
JENIYA_API_TOKEN=
JIANYI_ENDPOINT=http://jeniya.cn/v1/chat/completions

# 302.ai video provider.
VIDEO_PROVIDER=302ai
V302_API_KEY=
VIDEO_302_SUBMIT_URL=https://api.302.ai/302/submit/veo3-pro-frames
VIDEO_302_QUERY_URL=https://api.302.ai/302/submit/veo3-pro-frames
VIDEO_302_UPLOAD_URL=https://api.302.ai/302/upload-file
VIDEO_MODEL=veo3-pro-frames
VIDEO_SIZE=large
VIDEO_ENHANCE_PROMPT=true
VIDEO_ENABLE_UPSAMPLE=true
VIDEO_GENERATE_AUDIO=false

# Model names.
SCRIPT_MODEL=gpt-5.2-all
IMAGE_MODEL=gpt-image-1.5-all
TTS_MODEL=gpt-4o-mini-tts
META_MODEL=gpt-5.2-all
VISION_MODEL=gpt-5.2-all
YOUTUBE_ANALYSIS_MODEL=gpt-5.2-all
YOUTUBE_ANALYSIS_FALLBACK_MODELS=gpt-5-mini,gpt-4o-mini,qwen3.6-plus

# Optional S3/RustFS-compatible storage.
# The 302.ai upload API is used first for video input images. RustFS is a fallback.
RUSTFS_ENDPOINT=
RUSTFS_ACCESS_KEY=
RUSTFS_ACCESS_SECRET=
RUSTFS_BUCKET_NAME_VIDEO=video-clips
RUSTFS_BUCKET_NAME_AUDIO=audio-clips

# Optional integrations.
OPENROUTER_API_KEY=
YOUTUBE_API_KEY=
DASHSCOPE_API_KEY=
CAPCUT_API_URL=http://localhost:9000
